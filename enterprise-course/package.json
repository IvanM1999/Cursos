{
  "name": "enterprise-course-platform",
  "version": "1.0.0",
  "description": "Platform enterprise para cursos com sistema de autenticação, blogs e dicionário de serviços",
  "main": "backend/src/server.js",
  "scripts": {
    "start": "node backend/src/server.js",
    "dev": "node backend/src/utils/ServerBootstrap.js",
    "dev:watch": "node backend/src/utils/ServerBootstrap.js",
    "dev:simple": "nodemon backend/src/server.js --ignore node_modules",
    "test": "jest --coverage",
    "lint": "eslint .",
    "db:migrate": "node backend/src/config/migrate.js"
  },
  "keywords": [
    "enterprise",
    "course",
    "authentication",
    "mongodb",
    "postgresql"
  ],
  "author": "Enterprise Course Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "passport": "^0.6.0",
    "passport-local": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^5.8.0",
    "pg": "^8.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "multer": "^1.4.5-lts.1",
    "helmet": "^7.0.0",
    "express-validator": "^7.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "eslint": "^8.54.0",
    "@testing-library/jest-dom": "^6.1.5"
  }
}
